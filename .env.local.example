# Shelby Protocol — decentralised file storage
SHELBY_MOCK=true
SHELBY_NETWORK=shelbynet
SHELBY_API_KEY=
SHELBY_ACCOUNT_PRIVATE_KEY=

# App
NEXT_PUBLIC_BASE_URL=http://localhost:3000
